# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Base URL of the PHP API (no trailing slash)
PHP_API_BASE_URL=https://davidaedwards.com/ausfdclist

# Okta OIDC settings — create an OIDC app in your Okta org (Authorization Code + PKCE)
OKTA_CLIENT_ID=0oaXXXXXXXXXXXXXX
OKTA_ISSUER=https://your-org.okta.com/oauth2/default
OKTA_DOMAIN=https://your-org.okta.com
OKTA_REDIRECT_URI=http://localhost:8000/auth/callback
