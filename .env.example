# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Base URL of the PHP API (no trailing slash)
PHP_API_BASE_URL=https://davidaedwards.com/ausfdclist

# Okta OIDC settings — create an OIDC Web App in your Okta org (Authorization Code, confidential client)
OKTA_CLIENT_ID=0oaXXXXXXXXXXXXXX
OKTA_CLIENT_SECRET=your-client-secret
OKTA_ISSUER=https://your-org.okta.com/oauth2/default
OKTA_DOMAIN=https://your-org.okta.com
OKTA_REDIRECT_URI=http://localhost:8000/auth/callback

# Session cookie signing key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Okta STS Agent (Vaulted Secret token exchange via OPA Managed Connection)
# DB_USER and DB_PASS are no longer set here — they are retrieved at runtime via token exchange.
OKTA_AGENT_CLIENT_ID=0oa...
OKTA_AGENT_PRIVATE_JWK={"kty":"RSA","use":"sig","alg":"RS256","kid":"...","n":"...","e":"AQAB","d":"...","p":"...","q":"...","dp":"...","dq":"...","qi":"..."}
OKTA_DB_RESOURCE_INDICATOR=https://example.com/db/ausfdc-managed-connection
